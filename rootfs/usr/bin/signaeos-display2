#!/usr/bin/env bash
# signaeos-display2 — NDI viewer on workspace 2 (HDMI-A-2)
set -euo pipefail

CONFIG="/data/signaeos/config.json"
SOCKET="/run/signaeos/display2.sock"
NDI_PID=""
export XDG_RUNTIME_DIR="/run/user/1000"
export WAYLAND_DISPLAY="wayland-1"

log()  { logger -t "signaeos-display2" -- "$*"; echo "[$(date '+%H:%M:%S')] [d2] $*"; }
warn() { logger -t "signaeos-display2" -- "WARN: $*"; }
cfg()  { jq -r "$1" "$CONFIG" 2>/dev/null || echo "${2:-}"; }
cfg_set() { local t; t=$(mktemp); jq "$1 = $2" "$CONFIG" > "$t" && mv "$t" "$CONFIG"; }

sway_cmd() {
  local sock; sock=$(ls /run/user/1000/sway-ipc.*.sock 2>/dev/null | head -1 || true)
  [[ -n "$sock" ]] && SWAYSOCK="$sock" swaymsg "$@" 2>/dev/null || true
}

wait_display() {
  log "Waiting for Wayland..."
  local n=90
  while (( n-- > 0 )); do
    [[ -S "/run/user/1000/wayland-1" ]] && { log "Wayland ready"; return 0; }
    sleep 1
  done
}

kill_ndi() {
  if [[ -n "$NDI_PID" ]] && kill -0 "$NDI_PID" 2>/dev/null; then
    kill "$NDI_PID"; wait "$NDI_PID" 2>/dev/null || true; NDI_PID=""
    sleep 1
  fi
}

launch_ndi() {
  local source="$1"
  kill_ndi

  if [[ -z "$source" ]]; then
    log "No NDI source — workspace 2 empty"
    return
  fi

  log "NDI → $source"
  sway_cmd "workspace 2"
  sleep 0.5

  # Try VLC with NDI plugin
  if command -v vlc &>/dev/null; then
    # Check if NDI module is available
    if vlc --list 2>/dev/null | grep -qi ndi || ls /usr/lib/*/vlc/plugins/*ndi* 2>/dev/null | head -1 | grep -q .; then
      log "Using VLC NDI plugin"
      WAYLAND_DISPLAY=wayland-1 XDG_RUNTIME_DIR=/run/user/1000 \
      vlc --fullscreen --no-osd --no-video-title-show \
        --qt-minimal-view --no-qt-name-in-title \
        "ndi://${source}" 2>/dev/null &
      NDI_PID=$!
      sway_cmd '[app_id="vlc"] fullscreen enable'
      return
    fi
  fi

  # Try ndiplay from NDI SDK
  for p in /usr/local/bin/ndiplay /usr/bin/ndiplay /opt/ndi/bin/ndiplay; do
    if [[ -x "$p" ]]; then
      log "Using ndiplay: $p"
      WAYLAND_DISPLAY=wayland-1 XDG_RUNTIME_DIR=/run/user/1000 \
      "$p" -s "$source" 2>/dev/null &
      NDI_PID=$!
      return
    fi
  done

  # Fallback: show source name in browser on workspace 2
  warn "No NDI player found — showing placeholder"
  rm -f /data/chromium-d2/SingletonLock /data/chromium-d2/SingletonSocket 2>/dev/null || true
  WAYLAND_DISPLAY=wayland-1 XDG_RUNTIME_DIR=/run/user/1000 \
  chromium --kiosk --start-fullscreen --no-sandbox \
    --ozone-platform=wayland \
    --user-data-dir=/data/chromium-d2 \
    --app="data:text/html,<body style='margin:0;background:%23111;display:flex;align-items:center;justify-content:center;height:100vh'><div style='color:white;font-family:sans-serif;text-align:center'><p style='font-size:3vw;color:%23888'>NDI Source</p><p style='font-size:2.5vw'>${source}</p><p style='font-size:1.5vw;color:%23666;margin-top:20px'>Install VLC for video playback</p></div></body>" &
  NDI_PID=$!
  sleep 3
  sway_cmd '[app_id="chromium"] fullscreen enable'
}

handle_command() {
  local line; read -r -t 10 line || { echo '{"ok":false,"error":"timeout"}'; return; }
  local cmd; cmd=$(echo "$line" | jq -r '.cmd' 2>/dev/null || echo "")
  case "$cmd" in
    source)
      local name; name=$(echo "$line" | jq -r '.source // ""')
      cfg_set '.display2.current_source' "\"$name\""
      launch_ndi "$name"; echo '{"ok":true}' ;;
    next)
      local sources cur idx total
      sources=$(jq -r '[.display2.sources[].name]' "$CONFIG" 2>/dev/null || echo '[]')
      cur=$(cfg '.display2.current_source' "")
      total=$(echo "$sources" | jq 'length')
      (( total == 0 )) && echo '{"ok":false,"error":"no sources"}' && return
      idx=$(echo "$sources" | jq -r "index(\"$cur\") // -1")
      idx=$(( (idx + 1) % total ))
      local next; next=$(echo "$sources" | jq -r ".[$idx]")
      cfg_set '.display2.current_source' "\"$next\""
      launch_ndi "$next"; echo "{\"ok\":true,\"source\":\"$next\"}" ;;
    prev)
      local sources cur idx total
      sources=$(jq -r '[.display2.sources[].name]' "$CONFIG" 2>/dev/null || echo '[]')
      cur=$(cfg '.display2.current_source' "")
      total=$(echo "$sources" | jq 'length')
      (( total == 0 )) && echo '{"ok":false,"error":"no sources"}' && return
      idx=$(echo "$sources" | jq -r "index(\"$cur\") // 0")
      idx=$(( (idx - 1 + total) % total ))
      local prev; prev=$(echo "$sources" | jq -r ".[$idx]")
      cfg_set '.display2.current_source' "\"$prev\""
      launch_ndi "$prev"; echo "{\"ok\":true,\"source\":\"$prev\"}" ;;
    status)
      local src; src=$(cfg '.display2.current_source' "")
      echo "{\"ok\":true,\"display\":2,\"source\":\"$src\",\"pid\":${NDI_PID:-0}}" ;;
    *) echo '{"ok":false,"error":"unknown"}' ;;
  esac
}

[[ "${1:-}" == "--handle-command" ]] && { handle_command; exit 0; }

log "Display 2 (NDI) starting"
wait_display
mkdir -p /run/signaeos
rm -f "$SOCKET"
while true; do
  socat UNIX-LISTEN:"$SOCKET",fork EXEC:"$0 --handle-command" 2>/dev/null || sleep 2
done &

role=$(cfg '.role' "both")
[[ "$role" == "web" ]] && { log "Role=web, display2 inactive"; sleep infinity; }

launch_ndi "$(cfg '.display2.current_source' "")"

while true; do
  sleep 15
  if [[ -n "$NDI_PID" ]] && ! kill -0 "$NDI_PID" 2>/dev/null; then
    warn "NDI player died — restarting"; sleep 2
    launch_ndi "$(cfg '.display2.current_source' "")"
  fi
done
