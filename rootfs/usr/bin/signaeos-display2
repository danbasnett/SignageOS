#!/usr/bin/env bash
# signaeos-display2 — NDI viewer on workspace 2 (HDMI-A-2)
# Runs as admin user under sway
set -euo pipefail

CONFIG="/data/signaeos/config.json"
SOCKET="/run/signaeos/display2.sock"
NDI_PID=""
XDG_RUNTIME_DIR="/run/user/1000"
WAYLAND_DISPLAY="wayland-1"

export XDG_RUNTIME_DIR WAYLAND_DISPLAY

log()  { logger -t "signaeos-display2" -- "$*"; echo "[$(date '+%H:%M:%S')] [d2] $*"; }
warn() { logger -t "signaeos-display2" -- "WARN: $*"; }
cfg()  { jq -r "$1" "$CONFIG" 2>/dev/null || echo "${2:-}"; }
cfg_set() { local t; t=$(mktemp); jq "$1 = $2" "$CONFIG" > "$t" && mv "$t" "$CONFIG"; }

sway_msg() {
  local sock
  sock=$(ls /run/user/1000/sway-ipc.*.sock 2>/dev/null | head -1 || true)
  [[ -n "$sock" ]] && SWAYSOCK="$sock" swaymsg "$@" 2>/dev/null || true
}

wait_sway() {
  log "Waiting for Wayland socket..."
  local n=90
  while (( n-- > 0 )); do
    [[ -S "/run/user/1000/wayland-1" ]] && { log "Wayland ready"; return 0; }
    sleep 1
  done
  warn "Wayland not ready after 90s"
}

launch_ndi() {
  local source="$1"
  if [[ -n "$NDI_PID" ]] && kill -0 "$NDI_PID" 2>/dev/null; then
    kill "$NDI_PID"; wait "$NDI_PID" 2>/dev/null || true; NDI_PID=""; sleep 1
  fi

  if [[ -z "$source" ]]; then
    log "No NDI source — workspace 2 left empty (black)"
    NDI_PID=""
    return
  fi

  log "NDI → $source (workspace 2 / HDMI-A-2)"
  # Switch to workspace 2
  local sock; sock=$(ls /run/user/1000/sway-ipc.*.sock 2>/dev/null | head -1 || true)
  [[ -n "$sock" ]] && SWAYSOCK="$sock" swaymsg "workspace 2" 2>/dev/null || true
  sleep 0.3

  if command -v vlc &>/dev/null; then
    WAYLAND_DISPLAY=wayland-1 XDG_RUNTIME_DIR=/run/user/1000 \
    vlc --fullscreen --no-osd --no-video-title-show \
      --qt-minimal-view --no-qt-name-in-title \
      "ndi://${source}" &
    NDI_PID=$!
  else
    for p in /usr/local/bin/ndiplay /usr/bin/ndiplay; do
      [[ -x "$p" ]] && {
        WAYLAND_DISPLAY=wayland-1 XDG_RUNTIME_DIR=/run/user/1000 \
        "$p" -s "$source" -f &
        NDI_PID=$!
        break
      }
    done
    [[ -z "${NDI_PID:-}" ]] && warn "No NDI player — install vlc: sudo apt-get install vlc"
  fi
  log "NDI player PID: ${NDI_PID:-none}"
}

am_request() {
  local method="$1" path="$2" body="${3:-}"
  local ip; ip=$(cfg '.ndi.access_manager_ip' "")
  local port; port=$(cfg '.ndi.access_manager_port' "80")
  [[ -z "$ip" ]] && echo '{"error":"no AM"}' && return
  if [[ -n "$body" ]]; then
    curl -fsSL -X "$method" -H "Content-Type: application/json" -d "$body" \
      --connect-timeout 5 "http://${ip}:${port}${path}" 2>/dev/null || echo '{"error":"failed"}'
  else
    curl -fsSL -X "$method" --connect-timeout 5 "http://${ip}:${port}${path}" 2>/dev/null || echo '{"error":"failed"}'
  fi
}

handle_command() {
  local line; read -r -t 10 line || { echo '{"ok":false,"error":"timeout"}'; return; }
  local cmd; cmd=$(echo "$line" | jq -r '.cmd' 2>/dev/null || echo "")
  case "$cmd" in
    source)
      local name; name=$(echo "$line" | jq -r '.source // ""')
      cfg_set '.display2.current_source' "\"$name\""
      launch_ndi "$name"; echo '{"ok":true}' ;;
    next)
      local sources cur idx total
      sources=$(jq -r '[.display2.sources[].name]' "$CONFIG" 2>/dev/null || echo '[]')
      cur=$(cfg '.display2.current_source' "")
      total=$(echo "$sources" | jq 'length')
      (( total == 0 )) && echo '{"ok":false,"error":"no sources"}' && return
      idx=$(echo "$sources" | jq -r "index(\"$cur\") // -1")
      idx=$(( (idx + 1) % total ))
      local next; next=$(echo "$sources" | jq -r ".[$idx]")
      cfg_set '.display2.current_source' "\"$next\""
      launch_ndi "$next"; echo "{\"ok\":true,\"source\":\"$next\"}" ;;
    prev)
      local sources cur idx total
      sources=$(jq -r '[.display2.sources[].name]' "$CONFIG" 2>/dev/null || echo '[]')
      cur=$(cfg '.display2.current_source' "")
      total=$(echo "$sources" | jq 'length')
      (( total == 0 )) && echo '{"ok":false,"error":"no sources"}' && return
      idx=$(echo "$sources" | jq -r "index(\"$cur\") // 0")
      idx=$(( (idx - 1 + total) % total ))
      local prev; prev=$(echo "$sources" | jq -r ".[$idx]")
      cfg_set '.display2.current_source' "\"$prev\""
      launch_ndi "$prev"; echo "{\"ok\":true,\"source\":\"$prev\"}" ;;
    discover)
      local found="[]"
      for t in /usr/local/bin/ndi-discover /usr/local/bin/NDI_Find; do
        [[ -x "$t" ]] && found=$(timeout 4 "$t" 2>/dev/null | \
          awk '/Source:/{print $2}' | \
          jq -Rs 'split("\n") | map(select(length>0)) | map({name:.})' 2>/dev/null || echo "[]") && break
      done
      echo "{\"ok\":true,\"sources\":$found}" ;;
    am_sources)   echo "{\"ok\":true,\"data\":$(am_request GET /v1/sources)}" ;;
    am_groups)    echo "{\"ok\":true,\"data\":$(am_request GET /v1/groups)}" ;;
    am_receivers) echo "{\"ok\":true,\"data\":$(am_request GET /v1/receivers)}" ;;
    am_register)
      local name ip_addr
      name=$(cfg '.display_name' "SignageOS-D2")
      ip_addr=$(hostname -I 2>/dev/null | awk '{print $1}')
      echo "{\"ok\":true,\"data\":$(am_request POST /v1/receivers "{\"name\":\"$name\",\"ip\":\"$ip_addr\"}")}" ;;
    status)
      local src; src=$(cfg '.display2.current_source' "")
      echo "{\"ok\":true,\"display\":2,\"source\":\"$src\",\"ndi_pid\":${NDI_PID:-0}}" ;;
    *) echo '{"ok":false,"error":"unknown command"}' ;;
  esac
}

[[ "${1:-}" == "--handle-command" ]] && { handle_command; exit 0; }

log "Display 2 (NDI) starting"
wait_sway
mkdir -p /run/signaeos
rm -f "$SOCKET"
while true; do
  socat UNIX-LISTEN:"$SOCKET",fork EXEC:"$0 --handle-command" 2>/dev/null || sleep 2
done &

role=$(cfg '.role' "both")
if [[ "$role" == "web" ]]; then log "Role=web, display2 inactive"; sleep infinity; fi

launch_ndi "$(cfg '.display2.current_source' "")"

while true; do
  sleep 15
  if [[ -n "$NDI_PID" ]] && ! kill -0 "$NDI_PID" 2>/dev/null; then
    warn "NDI player died — restarting"; NDI_PID=""; sleep 2
    launch_ndi "$(cfg '.display2.current_source' "")"
  fi
done
