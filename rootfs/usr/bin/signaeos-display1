#!/usr/bin/env bash
# signaeos-display1 — Chromium kiosk on workspace 1 (HDMI-A-1)
set -euo pipefail

CONFIG="/data/signaeos/config.json"
SOCKET="/run/signaeos/display1.sock"
BROWSER_PID=""
export XDG_RUNTIME_DIR="/run/user/1000"
export WAYLAND_DISPLAY="wayland-1"

log()  { logger -t "signaeos-display1" -- "$*"; echo "[$(date '+%H:%M:%S')] [d1] $*"; }
warn() { logger -t "signaeos-display1" -- "WARN: $*"; }
cfg()  { jq -r "$1" "$CONFIG" 2>/dev/null || echo "${2:-}"; }
cfg_set() { local t; t=$(mktemp); jq "$1 = $2" "$CONFIG" > "$t" && mv "$t" "$CONFIG"; }

sway_exec() {
  # Atomically launch a command on a specific workspace via swaymsg
  local workspace="$1"; shift
  local cmd="$*"
  local sock
  sock=$(ls /run/user/1000/sway-ipc.*.sock 2>/dev/null | head -1 || true)
  if [[ -n "$sock" ]]; then
    SWAYSOCK="$sock" swaymsg "workspace ${workspace}; exec ${cmd}" 2>/dev/null || true
    return 0
  fi
  # Fallback: launch directly
  eval "$cmd" &
}

ensure_config() {
  mkdir -p /data/signaeos
  [[ -f "$CONFIG" ]] && return
  cat > "$CONFIG" <<'JSON'
{
  "role": "both",
  "display_name": "SignageOS",
  "display1": {
    "browser": "chromium",
    "current_index": 0,
    "urls": [{ "label": "Setup", "url": "http://localhost:3000" }]
  },
  "display2": { "current_source": "", "sources": [] },
  "ndi": { "devices": [], "discovery_server": "", "manual_sources": [] },
  "companion": { "server_ip": "", "server_port": 16622 },
  "network": { "hostname": "signaeos", "native_vlan": "", "vlans": [], "wifi_ssid": "", "wifi_password": "" },
  "ssh": { "authorized_keys": "" }
}
JSON
}

wait_sway() {
  log "Waiting for Wayland socket..."
  local n=60
  while (( n-- > 0 )); do
    [[ -S "/run/user/1000/wayland-1" ]] && { log "Wayland ready"; return 0; }
    sleep 1
  done
  warn "Wayland not ready after 60s — attempting anyway"
}

current_url() {
  local idx; idx=$(cfg '.display1.current_index' "0")
  cfg ".display1.urls[$idx].url" "http://localhost:3000"
}

launch_browser() {
  local url="$1"
  local browser; browser=$(cfg '.display1.browser' "chromium")

  # Kill existing
  if [[ -n "$BROWSER_PID" ]] && kill -0 "$BROWSER_PID" 2>/dev/null; then
    kill "$BROWSER_PID"; wait "$BROWSER_PID" 2>/dev/null || true; BROWSER_PID=""; sleep 1
  fi

  log "Launching $browser → $url (workspace 1)"

  # Kill existing
  if [[ -n "$BROWSER_PID" ]] && kill -0 "$BROWSER_PID" 2>/dev/null; then
    kill "$BROWSER_PID"; wait "$BROWSER_PID" 2>/dev/null || true; BROWSER_PID=""; sleep 1
  fi

  # Clean stale singleton locks
  rm -f /data/chromium-profile/SingletonLock /data/chromium-profile/SingletonSocket \
        /data/chromium-profile/SingletonCookie 2>/dev/null || true

  log "Launching $browser → $url (workspace 1)"

  # Switch to workspace 1 before launch
  local sock; sock=$(ls /run/user/1000/sway-ipc.*.sock 2>/dev/null | head -1 || true)
  [[ -n "$sock" ]] && SWAYSOCK="$sock" WAYLAND_DISPLAY=wayland-1 XDG_RUNTIME_DIR=/run/user/1000 \
    swaymsg "workspace 1" 2>/dev/null || true
  sleep 0.5

  case "$browser" in
    chromium*)
      # Use chromium directly (not chromium-browser wrapper which reorders flags)
      WAYLAND_DISPLAY=wayland-1 XDG_RUNTIME_DIR=/run/user/1000 \
      chromium \
        --kiosk \
        --no-sandbox \
        --noerrdialogs \
        --disable-infobars \
        --disable-session-crashed-bubble \
        --no-first-run \
        --disable-pinch \
        --autoplay-policy=no-user-gesture-required \
        --disable-background-networking \
        --disable-sync \
        --no-default-browser-check \
        --password-store=basic \
        --user-data-dir=/data/chromium-profile \
        --ozone-platform=wayland \
        --disable-features=TranslateUI,OverscrollHistoryNavigation \
        "$url" &
      BROWSER_PID=$!
      ;;
    firefox*)
      mkdir -p /data/firefox-profile
      [[ ! -f /data/firefox-profile/user.js ]] && cat > /data/firefox-profile/user.js <<'P'
user_pref("browser.sessionstore.resume_from_crash", false);
user_pref("browser.shell.checkDefaultBrowser", false);
user_pref("datareporting.policy.dataSubmissionEnabled", false);
P
      MOZ_ENABLE_WAYLAND=1 WAYLAND_DISPLAY=wayland-1 XDG_RUNTIME_DIR=/run/user/1000 \
      firefox-esr --kiosk --profile /data/firefox-profile --no-remote "$url" &
      BROWSER_PID=$!
      ;;
  esac
  log "Browser PID: $BROWSER_PID"
}

switch_url() {
  local idx="$1"
  local total; total=$(jq '.display1.urls | length' "$CONFIG" 2>/dev/null || echo 1)
  (( idx < 0 || idx >= total )) && echo '{"ok":false,"error":"index out of range"}' && return
  cfg_set '.display1.current_index' "$idx"
  launch_browser "$(cfg ".display1.urls[$idx].url" "http://localhost:3000")"
  echo '{"ok":true}'
}

handle_command() {
  local line; read -r -t 10 line || { echo '{"ok":false,"error":"timeout"}'; return; }
  local cmd cur total
  cmd=$(echo "$line" | jq -r '.cmd' 2>/dev/null || echo "")
  case "$cmd" in
    switch) switch_url "$(echo "$line" | jq -r '.index // 0')" ;;
    next)
      cur=$(cfg '.display1.current_index' "0")
      total=$(jq '.display1.urls | length' "$CONFIG" 2>/dev/null || echo 1)
      switch_url $(( (cur + 1) % total )) ;;
    prev)
      cur=$(cfg '.display1.current_index' "0")
      total=$(jq '.display1.urls | length' "$CONFIG" 2>/dev/null || echo 1)
      switch_url $(( (cur - 1 + total) % total )) ;;
    reload) launch_browser "$(current_url)"; echo '{"ok":true}' ;;
    status)
      local idx; idx=$(cfg '.display1.current_index' "0")
      total=$(jq '.display1.urls | length' "$CONFIG" 2>/dev/null || echo 1)
      echo "{\"ok\":true,\"display\":1,\"index\":$idx,\"label\":\"$(cfg ".display1.urls[$idx].label" "")\",\"url\":\"$(cfg ".display1.urls[$idx].url" "")\",\"total\":$total}" ;;
    *) echo '{"ok":false,"error":"unknown command"}' ;;
  esac
}

[[ "${1:-}" == "--handle-command" ]] && { handle_command; exit 0; }

log "Display 1 starting"
ensure_config
wait_sway
mkdir -p /run/signaeos
rm -f "$SOCKET"
while true; do
  socat UNIX-LISTEN:"$SOCKET",fork EXEC:"$0 --handle-command" 2>/dev/null || sleep 2
done &

role=$(cfg '.role' "both")
[[ "$role" == "ndi" ]] && { log "Role=ndi, display1 inactive"; sleep infinity; }

launch_browser "$(current_url)"
while true; do
  sleep 15
  if [[ -n "$BROWSER_PID" ]] && ! kill -0 "$BROWSER_PID" 2>/dev/null; then
    warn "Browser died — restarting"; BROWSER_PID=""; sleep 2
    launch_browser "$(current_url)"
  fi
done
