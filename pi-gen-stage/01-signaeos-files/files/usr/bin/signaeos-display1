#!/usr/bin/env bash
# signaeos-display1 — Chromium kiosk on workspace 1 (HDMI-A-1)
# Uses a kiosk proxy page — Chromium launches ONCE and never restarts for URL changes.
# URL switching is handled by the proxy page polling /api/display/1/status
set -euo pipefail

CONFIG="/data/signaeos/config.json"
SOCKET="/run/signaeos/display1.sock"
BROWSER_PID=""
KIOSK_URL="http://localhost:3000/kiosk/display1"
export XDG_RUNTIME_DIR="${XDG_RUNTIME_DIR:-/run/signaeos-runtime}"

log()  { logger -t "signaeos-display1" -- "$*"; echo "[$(date '+%H:%M:%S')] [d1] $*"; }
warn() { logger -t "signaeos-display1" -- "WARN: $*"; }
cfg()  { jq -r "$1" "$CONFIG" 2>/dev/null || echo "${2:-}"; }
cfg_set() { local t; t=$(mktemp); jq "$1 = $2" "$CONFIG" > "$t" && mv "$t" "$CONFIG"; }
json() { jq -cn "$@"; }

detect_wayland() {
  local sock
  sock=$(find "$XDG_RUNTIME_DIR" -maxdepth 1 -type s -name 'wayland-*' 2>/dev/null | sort | head -1 || true)
  if [[ -n "$sock" ]]; then
    export WAYLAND_DISPLAY="$(basename "$sock")"
  else
    export WAYLAND_DISPLAY="${WAYLAND_DISPLAY:-wayland-0}"
  fi
}

sway_cmd() {
  local sock; sock=$(find "$XDG_RUNTIME_DIR" -maxdepth 1 -type s -name 'sway-ipc.*.sock' 2>/dev/null | sort | head -1 || true)
  [[ -n "$sock" ]] && SWAYSOCK="$sock" swaymsg "$@" 2>/dev/null || true
}

browser_cmd() {
  local p
  for p in chromium-browser chromium /usr/bin/chromium-browser /usr/bin/chromium /usr/lib/chromium/chromium; do
    if [[ "$p" == /* && -x "$p" ]]; then echo "$p"; return 0; fi
    if [[ "$p" != /* ]] && command -v "$p" >/dev/null 2>&1; then command -v "$p"; return 0; fi
  done
  return 1
}

wait_display() {
  log "Waiting for Wayland..."
  local n=60
  while (( n-- > 0 )); do
    detect_wayland
    [[ -S "$XDG_RUNTIME_DIR/$WAYLAND_DISPLAY" ]] && { log "Wayland ready ($WAYLAND_DISPLAY)"; return 0; }
    sleep 1
  done
  warn "Wayland not ready — continuing anyway"
}

launch_browser() {
  local browser
  browser=$(browser_cmd) || { warn "Chromium executable not found"; return 1; }

  # Clean stale locks
  rm -f /data/chromium-profile/SingletonLock \
        /data/chromium-profile/SingletonSocket \
        /data/chromium-profile/SingletonCookie 2>/dev/null || true

  log "Launching Chromium kiosk → $KIOSK_URL"

  # Switch to workspace 1 before launch
  sway_cmd "workspace 1"
  sleep 0.5

  WAYLAND_DISPLAY="$WAYLAND_DISPLAY" XDG_RUNTIME_DIR="$XDG_RUNTIME_DIR" \
  "$browser" \
    --kiosk \
    --start-fullscreen \
    --no-sandbox \
    --noerrdialogs \
    --disable-infobars \
    --disable-session-crashed-bubble \
    --no-first-run \
    --disable-pinch \
    --autoplay-policy=no-user-gesture-required \
    --disable-background-networking \
    --disable-sync \
    --no-default-browser-check \
    --password-store=basic \
    --user-data-dir=/data/chromium-profile \
    --ozone-platform=wayland \
    --disable-features=TranslateUI,OverscrollHistoryNavigation \
    --remote-debugging-port=9222 \
    --remote-allow-origins='http://localhost:3000' \
    "$KIOSK_URL" &
  BROWSER_PID=$!
  log "Browser PID: $BROWSER_PID"

  # Force fullscreen after Chromium initialises
  sleep 3
  sway_cmd '[app_id="chromium"] fullscreen enable'
}

handle_command() {
  local line; read -r -t 10 line || { echo '{"ok":false,"error":"timeout"}'; return; }
  local cmd; cmd=$(echo "$line" | jq -r '.cmd' 2>/dev/null || echo "")
  case "$cmd" in
    switch)
      # Just update config — kiosk proxy page picks it up within 1 second
      local idx; idx=$(echo "$line" | jq -r '.index // 0')
      local total; total=$(jq '.display1.urls | length' "$CONFIG" 2>/dev/null || echo 1)
      if (( idx < 0 || idx >= total )); then
        echo '{"ok":false,"error":"index out of range"}'; return
      fi
      cfg_set '.display1.current_index' "$idx"
      echo '{"ok":true}'
      ;;
    next)
      local cur total
      cur=$(cfg '.display1.current_index' "0")
      total=$(jq '.display1.urls | length' "$CONFIG" 2>/dev/null || echo 1)
      local next=$(( (cur + 1) % total ))
      cfg_set '.display1.current_index' "$next"
      echo '{"ok":true}'
      ;;
    prev)
      local cur total
      cur=$(cfg '.display1.current_index' "0")
      total=$(jq '.display1.urls | length' "$CONFIG" 2>/dev/null || echo 1)
      local prev=$(( (cur - 1 + total) % total ))
      cfg_set '.display1.current_index' "$prev"
      echo '{"ok":true}'
      ;;
    reload)
      # Kill and relaunch browser if needed
      if [[ -n "$BROWSER_PID" ]] && kill -0 "$BROWSER_PID" 2>/dev/null; then
        kill "$BROWSER_PID"; wait "$BROWSER_PID" 2>/dev/null || true; BROWSER_PID=""
      fi
      launch_browser
      echo '{"ok":true}'
      ;;
    status)
      local idx; idx=$(cfg '.display1.current_index' "0")
      local total; total=$(jq '.display1.urls | length' "$CONFIG" 2>/dev/null || echo 1)
      local url; url=$(cfg ".display1.urls[$idx].url" "")
      local label; label=$(cfg ".display1.urls[$idx].label" "")
      json --arg label "$label" --arg url "$url" \
        --argjson index "$idx" --argjson total "$total" \
        '{ok:true, display:1, index:$index, label:$label, url:$url, total:$total}'
      ;;
    *) echo '{"ok":false,"error":"unknown command"}' ;;
  esac
}

[[ "${1:-}" == "--handle-command" ]] && { handle_command; exit 0; }

log "Display 1 starting"
wait_display

mkdir -p /run/signaeos
rm -f "$SOCKET"
while true; do
  socat UNIX-LISTEN:"$SOCKET",fork EXEC:"$0 --handle-command" 2>/dev/null || sleep 2
done &

role=$(cfg '.role' "both")
[[ "$role" == "ndi" ]] && { log "Role=ndi, display1 inactive"; sleep infinity; }

launch_browser

while true; do
  sleep 15
  if [[ -n "$BROWSER_PID" ]] && ! kill -0 "$BROWSER_PID" 2>/dev/null; then
    warn "Browser died — restarting"; BROWSER_PID=""; sleep 2
    launch_browser
  fi
done
